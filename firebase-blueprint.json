{
  "entities": {
    "CustomDesign": {
      "title": "Custom Design",
      "description": "A custom test format design created by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the design." },
        "name": { "type": "string", "description": "Name of the design." },
        "type": { "type": "string", "description": "Type of test (e.g., mcq, tf, matching)." },
        "category": { "type": "string", "description": "Category (e.g., Grammar, Vocabulary)." },
        "style": { "type": "object", "description": "Style configuration object." },
        "prompt": { "type": "string", "description": "AI instructions for this design." },
        "uid": { "type": "string", "description": "User ID of the owner." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["id", "name", "type", "category", "style", "uid", "createdAt"]
    },
    "UserSetting": {
      "title": "User Setting",
      "description": "Global settings for the user's workspace.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID." },
        "brandSettings": { "type": "object", "description": "Branding and logo settings." },
        "paperStyles": { "type": "object", "description": "Default paper styles for different test types." },
        "paperDesign": { "type": "number", "description": "Selected header design style ID." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["uid", "updatedAt"]
    }
  },
  "firestore": {
    "/custom_designs/{designId}": {
      "schema": "CustomDesign",
      "description": "Collection of custom test designs."
    },
    "/user_settings/{userId}": {
      "schema": "UserSetting",
      "description": "User-specific settings and preferences."
    }
  }
}
