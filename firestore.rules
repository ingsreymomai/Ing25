rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: custom_designs
    // Document ID: {designId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required, 1-100 chars)
    //   - type: string (required, enum: mcq, tf, matching, etc.)
    //   - category: string (required)
    //   - style: map (required)
    //   - prompt: string (optional)
    //   - uid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: user_settings
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - brandSettings: map (optional)
    //   - paperStyles: map (optional)
    //   - paperDesign: number (optional)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidTimestamp(field) {
      return request.resource.data[field] is timestamp;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidCustomDesign(data) {
      return hasRequiredFields(['id', 'name', 'type', 'category', 'style', 'uid', 'createdAt']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type is string &&
             data.category is string &&
             data.style is map &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidUserSetting(data) {
      return hasRequiredFields(['uid', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /custom_designs/{designId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidCustomDesign(request.resource.data);
      allow update: if isDocOwner() && isValidCustomDesign(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /generatedTests/{testId} {
      allow read: if resource.data.authorEmail == 'public@dpss.edu' || (isAuthenticated() && resource.data.authorEmail == request.auth.token.email);
      allow create: if request.resource.data.authorEmail == 'public@dpss.edu' || (isAuthenticated() && request.resource.data.authorEmail == request.auth.token.email);
      allow update: if (resource.data.authorEmail == 'public@dpss.edu' && request.resource.data.authorEmail == 'public@dpss.edu') || 
                      (isAuthenticated() && resource.data.authorEmail == request.auth.token.email && request.resource.data.authorEmail == request.auth.token.email);
      allow delete: if resource.data.authorEmail == 'public@dpss.edu' || (isAuthenticated() && resource.data.authorEmail == request.auth.token.email);
    }

    match /user_settings/{userId} {
      allow read: if userId == 'public@dpss.edu' || isOwner(userId) || (isAuthenticated() && request.auth.token.email == userId);
      allow create: if userId == 'public@dpss.edu' || isOwner(userId) || (isAuthenticated() && request.auth.token.email == userId);
      allow update: if userId == 'public@dpss.edu' || isOwner(userId) || (isAuthenticated() && request.auth.token.email == userId);
      allow delete: if userId == 'public@dpss.edu' || isOwner(userId) || (isAuthenticated() && request.auth.token.email == userId);
    }
  }
}
